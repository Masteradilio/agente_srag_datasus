# Copie este arquivo para .env e substitua os placeholders pelas suas chaves reais.
OPENAI_API_KEY=sua_api_key_aqui
# Opcional para provedores OpenAI-compatible:
# NVIDIA_API_KEY=sua_api_key_aqui
# LLM_API_KEY=sua_api_key_aqui
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
DISABLE_LLM_API=0
APP_ENV=local
